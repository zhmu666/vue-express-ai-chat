第 1 步：先把“消息渲染”做对（不接 AI 也要先通）
1）先定义消息类型（TS）
src/types/chat.ts

export type Role = "user" | "assistant";

export type MessageStatus = "sending" | "streaming" | "done" | "error" | "stopped";

export interface Message {
  id: string;
  role: Role;
  content: string;
  status: MessageStatus;
  createdAt: number;
}
2）Pinia store：能 addMessage + updateMessage
src/stores/chat.ts

import { defineStore } from "pinia";
import type { Message, Role, MessageStatus } from "@/types/chat";

function genId(prefix = "msg") {
  return `${prefix}_${Date.now()}_${Math.random().toString(16).slice(2)}`;
}

export const useChatStore = defineStore("chat", {
  state: () => ({
    messages: [] as Message[],
  }),

  actions: {
    addMessage(role: Role, content: string, status: MessageStatus = "done") {
      const msg: Message = {
        id: genId(role),
        role,
        content,
        status,
        createdAt: Date.now(),
      };
      this.messages.push(msg);
      return msg.id;
    },

    updateMessage(id: string, patch: Partial<Message>) {
      const m = this.messages.find((x) => x.id === id);
      if (!m) return;
      Object.assign(m, patch);
    },

    appendToMessage(id: string, delta: string) {
      const m = this.messages.find((x) => x.id === id);
      if (!m) return;
      m.content += delta;
    },
  },
});
3）Chat.vue：先能“输入→显示两条消息（用户+机器人占位）”
src/views/Chat.vue

<template>
  <div class="chat">
    <div ref="listRef" class="list">
      <div v-for="m in chat.messages" :key="m.id" class="msg" :class="m.role">
        <div class="role">{{ m.role }}</div>
        <div class="content">{{ m.content }}</div>
        <div class="status">{{ m.status }}</div>
      </div>
    </div>

    <form class="input" @submit.prevent="onSend">
      <input v-model="text" placeholder="输入消息..." />
      <button :disabled="!text.trim()">发送</button>
    </form>
  </div>
</template>

<script setup lang="ts">
import { nextTick, ref } from "vue";
import { useChatStore } from "@/stores/chat";

const chat = useChatStore();
const text = ref("");
const listRef = ref<HTMLElement | null>(null);

function scrollToBottom() {
  nextTick(() => {
    if (!listRef.value) return;
    listRef.value.scrollTop = listRef.value.scrollHeight;
  });
}

function onSend() {
  const content = text.value.trim();
  if (!content) return;

  chat.addMessage("user", content, "done");
  chat.addMessage("assistant", "正在生成...", "streaming");

  text.value = "";
  scrollToBottom();
}
</script>

