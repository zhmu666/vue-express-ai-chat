4.1 新建 src/types/chat.ts
export type Role = "user" | "assistant";

export type MessageStatus = "sending" | "streaming" | "done" | "error" | "stopped";

export interface Message {
  id: string;
  role: Role;
  content: string;
  status: MessageStatus;
  createdAt: number;
