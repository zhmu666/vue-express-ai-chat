2）前端：流式解析（更稳 + 报错可见）
✅ src/api/chat.ts
type ChatMessage = { role: string; content: string };

export async function streamChat(
  messages: ChatMessage[],
  onDelta: (delta: string) => void,
  signal?: AbortSignal
) {
  const res = await fetch("/api/chat", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ messages }),
    signal,
  });

  // 关键：非 2xx 直接抛错（否则 404/500 也会被当“正常结束”）
  if (!res.ok) {
    const text = await res.text().catch(() => "");
    throw new Error(`HTTP ${res.status}: ${text.slice(0, 200)}`);
  }

  if (!res.body) throw new Error("No response body");

  const reader = res.body.getReader();
  const decoder = new TextDecoder("utf-8");

  // 关键：SSE 可能跨 chunk，必须做 buffer
  let buffer = "";

  while (true) {
    const { done, value } = await reader.read();
    if (done) break;

    buffer += decoder.decode(value, { stream: true });

    // SSE 事件之间通常用 \n\n 分隔
    const events = buffer.split("\n\n");
    buffer = events.pop() ?? "";

    for (const evt of events) {
      const lines = evt.split("\n");
      for (const line of lines) {
        if (!line.startsWith("data:")) continue;

        const data = line.slice(5).trim();
        if (!data) continue;
        if (data === "[DONE]") return;

        try {
          const json = JSON.parse(data);
          const choice = json.choices?.[0];

          // 兼容 delta / message 两种
          const delta =
            choice?.delta?.content ??
            choice?.message?.content ??
            "";

          if (delta) onDelta(delta);
        } catch {
          // 忽略偶发解析失败（通常是拆包导致），buffer 机制已大幅减少
        }
      }
    }
  }
}
3）前端：Chat 页面（接入 stream + 错误显示更清晰）
✅ src/views/Chat.vue（你已有就替换 script 部分即可）
<template>
  <div class="chat">
    <header class="header">
      <div class="title">AI Chat</div>
      <button class="btn" @click="chat.clear()">清空</button>
    </header>

    <div ref="listRef" class="list">
      <div v-for="m in chat.messages" :key="m.id" class="msg" :class="m.role">
        <div class="meta">
          <span class="role">{{ m.role }}</span>
          <span class="status">{{ m.status }}</span>
        </div>
        <div class="content">{{ m.content }}</div>
      </div>
    </div>

    <form class="input" @submit.prevent="onSend">
      <input v-model="text" placeholder="输入消息…" />
      <button class="btn" :disabled="!text.trim()">发送</button>
    </form>
  </div>
</template>

<script setup lang="ts">
import { nextTick, ref } from "vue";
import { useChatStore } from "@/stores/chat";
import { streamChat } from "@/api/chat";

const chat = useChatStore();
const text = ref("");
const listRef = ref<HTMLElement | null>(null);

function scrollToBottom() {
  nextTick(() => {
    if (!listRef.value) return;
    listRef.value.scrollTop = listRef.value.scrollHeight;
  });
}

async function onSend() {
  const content = text.value.trim();
  if (!content) return;

  // 1) 用户消息
  chat.addMessage("user", content, "done");

  // 2) assistant 占位
  const assistantId = chat.addMessage("assistant", "", "streaming");

  text.value = "";
  scrollToBottom();

  try {
    await streamChat(
      chat.messages.map((m) => ({ role: m.role, content: m.content })),
      (delta) => {
        chat.appendToMessage(assistantId, delta);
        scrollToBottom();
      }
    );

    chat.updateMessage(assistantId, { status: "done" });
  } catch (e: any) {
    chat.updateMessage(assistantId, {
      status: "error",
      content: `请求失败：${e?.message ?? "unknown error"}`,
    });
  }
}
</script>

